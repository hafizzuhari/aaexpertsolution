---
import Nav from "../components/Nav.astro"
import Footer from "../components/Footer.astro"
import { openGraph, seo } from "../content/0-seo"
import { contact } from "../content/8-contact"
import "../styles/global.css"

const t = "$store.locale.value === 'ms' ? $el.dataset.ms : $el.dataset.en";
const phoneItem = contact.items.find((item) => item.type === "phone");
const waNumber = phoneItem ? phoneItem.label.replace(/\D/g, "") : "";
---
<!doctype html>
<html lang="ms" data-theme="aa-expert-solution" x-data x-bind:lang="$store.locale.value === 'ms' ? 'ms' : 'en'">
	<head>
		<script is:inline>
			document.addEventListener("alpine:init", () => {
				// @ts-ignore
				Alpine.store("locale", {
					value: localStorage.getItem("aaes-locale") || "ms",
					toggle() {
						this.value = this.value === "ms" ? "en" : "ms";
						localStorage.setItem("aaes-locale", this.value);
					},
				});
			});
		</script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/jpg" href="/favicon.webp" />
		<meta name="generator" content={Astro.generator} />
		<title>{seo.title}</title>
		<meta name="description" content={seo.description}>
		<meta name="keywords" content={seo.keywords}>
		<meta property="og:title" content={openGraph.title} />
		<meta property="og:description" content={openGraph.description} />
		<meta property="og:type" content={openGraph.type} />
		<meta property="og:url" content={openGraph.url} />
		<meta property="og:image" content={openGraph.image} />
		<meta property="og:locale" content={openGraph.locale} />
		<meta property="og:site_name" content={openGraph.site_name} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Archivo:wght@700;900&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
			rel="stylesheet"
			media="print"
			onload="this.media='all'"
		/>
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.44.0/dist/tabler-icons.min.css"
			media="print"
			onload="this.media='all'"
		/>
		<link
			rel="stylesheet"
			href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
			integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
			crossorigin=""
			media="print"
			onload="this.media='all'"
		/>
		<noscript>
			<link href="https://fonts.googleapis.com/css2?family=Archivo:wght@700;900&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet" />
			<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.44.0/dist/tabler-icons.min.css" />
			<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
		</noscript>
		<script defer src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
		<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.15.12/dist/cdn.min.js"></script>
	</head>
	<body>
		<a
			href={`https://wa.me/${waNumber}`}
			target="_blank"
			rel="noopener"
			class="aa-wa-btn fixed right-4 bottom-4 lg:right-6 lg:bottom-6 z-40 flex items-center h-[56px] overflow-hidden rounded-full bg-[#25d366] text-white shadow-xl"
		>
			<span class="w-[56px] h-[56px] flex items-center justify-center shrink-0"><i class="ti ti-brand-whatsapp text-2xl"></i></span>
			<span class="font-bold text-sm whitespace-nowrap pr-5" data-ms="Chat WhatsApp" data-en="Chat on WhatsApp" x-text={t}>Chat WhatsApp</span>
		</a>
		<header>
			<Nav />
		</header>
		<main>
			<slot />
		</main>
		<footer>
			<Footer />
		</footer>
	</body>
</html>

<style is:global>
	:root:has(input.theme-controller[value=aa-expert-solution]:checked),[data-theme="aa-expert-solution"] {
		--color-base-100: #f5f2ec;
		--color-base-200: #eae7e0;
		--color-base-300: #d6d3cc;
		--color-base-content: #2a2a2a;

		--color-primary: #d2902b;
		--color-primary-content: #ffffff;

		--color-secondary: #2a2a2a;
		--color-secondary-content: #ffffff;

		--color-accent: #ffc857;
		--color-accent-content: #2a2a2a;

		--color-neutral: #333333;
		--color-neutral-content: #ffffff;

		--color-info: #57a6ff;
		--color-info-content: #002e5d;

		--color-success: #45b26b;
		--color-success-content: #ffffff;

		--color-warning: #ffc857;
		--color-warning-content: #3f2c00;

		--color-error: #d9534f;
		--color-error-content: #ffffff;

		/* --radius-selector: 0.5rem;
		--radius-field: 0.25rem;
		--radius-box: 0.5rem; */

		--radius-selector: 0rem;
		--radius-field: 0rem;
		--radius-box: 0rem;

		--size-selector: 0.25rem;
		--size-field: 0.25rem;

		--border: 1px;
		--depth: 1;
		--noise: 0;
	}

	* {
		font-family: "Montserrat", sans-serif;
		font-optical-sizing: auto;
		font-weight: 400;
		font-style: normal;
	}

	h1, h2, h3, h4, h5, h6 {
		font-family: "Archivo", "Montserrat", sans-serif;
		font-weight: 900;
		text-transform: uppercase;
		letter-spacing: 0.02em;
	}

	[x-cloak] {
		display: none !important;
	}

	.aa-tex-dark {
		background-image: repeating-linear-gradient(0deg, rgba(255,255,255,0.028) 0 1px, transparent 1px 26px), repeating-linear-gradient(90deg, rgba(255,255,255,0.028) 0 1px, transparent 1px 26px);
	}
	.aa-tex-orange {
		background-image: repeating-linear-gradient(0deg, rgba(42,42,42,0.05) 0 1px, transparent 1px 26px), repeating-linear-gradient(90deg, rgba(42,42,42,0.05) 0 1px, transparent 1px 26px);
	}

	@keyframes aaKen { from { transform: scale(1.0); } to { transform: scale(1.12); } }
	@keyframes aaFade { from { opacity: 0; } to { opacity: 1; } }
	@keyframes aaRise { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: none; } }
	@keyframes aaReveal { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: none; } }
	@keyframes aaPulse { 0%,100% { box-shadow: 0 0 0 0 rgba(37,211,102,0.5); } 50% { box-shadow: 0 0 0 12px rgba(37,211,102,0); } }

	.aa-reveal { animation: aaReveal both linear; animation-timeline: view(); animation-range: entry 4% entry 38%; }
	.aa-lift { transition: transform 0.35s ease, box-shadow 0.35s ease; }
	.aa-lift:hover { transform: translateY(-6px); }
	.aa-media img { transition: transform 0.6s ease; }
	.aa-media:hover img { transform: scale(1.07); }
	.aa-wa-btn { animation: aaPulse 2.6s infinite; }

	@media (prefers-reduced-motion: reduce) {
		.aa-reveal, .aa-wa-btn { animation: none; }
		.aa-lift, .aa-media img { transition: none; }
	}
</style>
